# ABD-Cafe 后端环境变量配置示例
# 复制此文件为 .env 并填入实际值

# 服务器配置
NODE_ENV=production
PORT=3001

# JWT 密钥（请替换为强随机字符串）
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT 过期时间
JWT_EXPIRES_IN=7d

# 前端域名（用于 CORS 配置）
FRONTEND_URL=https://kaka2772.cc

# 数据库配置（如果使用 MySQL）
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=abd_cafe
# DB_PASSWORD=your_password
# DB_NAME=abd_cafe_db

# 日志级别
LOG_LEVEL=info
